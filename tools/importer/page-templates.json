{
  "metadata": {
    "projectType": "da"
  },
  "templates": [
    {
      "name": "executive-mba-brochure",
      "urls": [
        "https://iem-brochures.ie.edu/.executive.mba/"
      ],
      "description": "IE Executive MBA brochure landing page with program information and application details",
      "blocks": [
        { "name": "hero-cover", "instances": ["#excat-captured figure.spread-page-1"] },
        { "name": "table-specs", "instances": ["#excat-captured figure.spread-page-2", "#excat-captured figure.spread-page-3"] },
        { "name": "columns-textimg", "instances": ["#excat-captured figure.spread-page-4"] },
        { "name": "highlight-text", "instances": ["#excat-captured figure.spread-page-6"] },
        { "name": "ranking", "instances": ["#excat-captured figure.spread-page-7"] },
        { "name": "feature-textimg", "instances": ["#excat-captured figure.spread-page-8"] },
        { "name": "accordion", "instances": ["#excat-captured figure.spread-page-9"] },
        { "name": "profile-stats", "instances": ["#excat-captured figure.spread-page-10"] },
        { "name": "logo-marquee", "instances": ["#excat-captured figure.spread-page-11"] },
        { "name": "alumni-story", "instances": ["#excat-captured figure.spread-page-13"] }
      ],
      "sections": [
        { "id": "section-1-cover", "name": "Cover / Hero", "selector": "#excat-captured [data-section=\"section-1-cover\"]", "style": "dark", "blocks": ["hero-cover"], "defaultContent": [] },
        { "id": "section-2-el-programa", "name": "El Programa - Overview", "selector": "#excat-captured [data-section=\"section-2-el-programa\"]", "style": "dark", "blocks": ["table-specs"], "defaultContent": [] },
        { "id": "section-3-introduction", "name": "El Programa - Introduction Text", "selector": "#excat-captured [data-section=\"section-3-introduction\"]", "style": null, "blocks": ["columns-textimg"], "defaultContent": [] },
        { "id": "section-4-coach-ranking", "name": "Coach statement + ranking", "selector": "#excat-captured [data-section=\"section-4-coach-ranking\"]", "style": null, "blocks": ["highlight-text", "ranking"], "defaultContent": [] },
        { "id": "section-5-opcion-ideal", "name": "La opción ideal + perfil", "selector": "#excat-captured [data-section=\"section-5-opcion-ideal\"]", "style": null, "blocks": ["feature-textimg", "accordion"], "defaultContent": [] },
        { "id": "section-6-contactos", "name": "Contactos para toda la vida", "selector": "#excat-captured [data-section=\"section-6-contactos\"]", "style": null, "blocks": ["profile-stats", "logo-marquee"], "defaultContent": [] },
        { "id": "section-7-alumni", "name": "Marcando la diferencia", "selector": "#excat-captured [data-section=\"section-7-alumni\"]", "style": null, "blocks": ["alumni-story"], "defaultContent": [] }
      ]
    }
  ]
}
